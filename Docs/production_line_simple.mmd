graph LR

    classDef equip    fill:#2C3E50,stroke:#85929E,color:#fff
    classDef bin      fill:#F39C12,stroke:#D68910,color:#000
    classDef crusher  fill:#922B21,stroke:#641E16,color:#fff
    classDef pump     fill:#1A5276,stroke:#0E3460,color:#fff
    classDef malax    fill:#1D6A39,stroke:#145A32,color:#fff
    classDef extract  fill:#4A235A,stroke:#2E1740,color:#fff
    classDef product  fill:#117A65,stroke:#0E6655,color:#fff

    WASH(["🧼 Πλυντήριο<br/>Ελαιόκαρπου"])

    subgraph WEIGHING["⚖️  Ζυγιστήριο"]
        direction TB
        BIN1["📦 Κάδος ①<br/>Συγκράτησης<br/>― κλαπέτο + έμβολο ―"]
        BIN2["⚖️ Κάδος ②<br/>Ζύγισης<br/>― 2× Load Cell 50 kg ―"]
        BIN1 --> BIN2
    end

    ELV["🏗️ ①<br/>Αναβατόριο<br/>Σπαστήρα<br/>3,0 HP"]

    FSCR["⚙️ ②<br/>Προωθητής<br/>Σπαστήρα<br/>1,5 HP"]

    CRUSHER["💥 ③<br/>Σπαστήρας<br/>60,0 HP"]

    PSCR["⚙️ ④<br/>Κοχλίας<br/>Εμβολοφόρας<br/>1,5 HP"]

    subgraph FEED["🟠  Τροφοδοσία Μαλακτήρων  ⑤–⑧"]
        MPUMP["🔵 Εμβολοφόρα<br/>Μαλακτήρα<br/>10,0 HP<br/>HEATEX No1 + No2"]
        DPIPE["🔀 Σωλήνας Διανομής<br/>Χ πνευματικές βάνες"]
        MPUMP --> DPIPE
    end

    subgraph MALAXATORS["🟢  Συγκρότημα Μαλακτήρων ⑨  —  Χ × 3,0 HP"]
        direction TB
        MAL1["🌿 Μαλακτήρας 1<br/>3,0 HP"]
        MAL2["🌿 Μαλακτήρας 2<br/>3,0 HP"]
        MALN["🌿 Μαλακτήρας Ν<br/>3,0 HP"]
    end

    COLLECT["⚙️ ⑩<br/>Τροφοδότης<br/>Αντλίας<br/>3,0 HP"]

    ISCR["⚙️ ⑪<br/>Κεκλιμένος<br/>Κοχλίας<br/>3,0 HP"]

    FMAL["🌀 ⑫<br/>Τελικός<br/>Μαλακτήρας<br/>3,0 HP"]

    APUMP["🔵 ⑬<br/>Αντλία<br/>Ελαιόζυμης<br/>7,5 HP"]

    DEC["🌀 ⑭<br/>Decanter<br/>75,0 HP"]

    OIL(["🫙 Λάδι<br/>→ Δονητικό Φίλτρο"])
    POMACE(["🪨 Πυρήνας<br/>→ Κοχλίας Εξαγωγής"])

    %% ── Main flow ──────────────────────────────────────────────────
    WASH      --> BIN1
    BIN2      --> ELV
    ELV       --> FSCR
    FSCR      --> CRUSHER
    CRUSHER   --> PSCR
    PSCR      --> MPUMP
    DPIPE     --> MAL1
    DPIPE     --> MAL2
    DPIPE     --> MALN
    MAL1      --> COLLECT
    MAL2      --> COLLECT
    MALN      --> COLLECT
    COLLECT   --> ISCR
    ISCR      --> FMAL
    FMAL      --> APUMP
    APUMP     --> DEC
    DEC       --> OIL
    DEC       --> POMACE

    %% ── Classes ────────────────────────────────────────────────────
    class WASH equip
    class BIN1,BIN2 bin
    class ELV,FSCR,PSCR equip
    class CRUSHER crusher
    class MPUMP,APUMP pump
    class DPIPE equip
    class MAL1,MAL2,MALN malax
    class COLLECT,ISCR,FMAL extract
    class DEC extract
    class OIL,POMACE product
