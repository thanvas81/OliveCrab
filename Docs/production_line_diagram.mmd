    %% ── Phase 1 → Phase 2 ──────────────────────────────────────────
    S6 -->|"Ελιές → Αναβατόριο"| ELV
    S8 -->|"Τελευταίος κύκλος → Αναβατόριο"| ELV

    %% ── Crushing sequence ──────────────────────────────────────────
    ELV --> FSCR
    FSCR --> CRUSHER
    CRUSHER --> PSCR
    PSCR --> MPUMP

    %% ── Feed → Distribution ────────────────────────────────────────
    MPUMP --> DPIPE

    %% ── Distribution → Fill Valves ─────────────────────────────────
    DPIPE -->|"🔓 Βάνα ① ανοίγει"| M1_FV
    DPIPE -->|"🔓 Βάνα ② ανοίγει"| M2_FV
    DPIPE -->|"🔓 Βάνα Ν ανοίγει"| MN_FV

    %% ── Malaxator 1 ────────────────────────────────────────────────
    M1_FV  --> M1_MOT
    M1_H   -.->|"Θέρμανση σερπαντίνας"| M1_MOT
    M1_MOT -->|"Παρακολούθηση"| M1_S
    M1_S   -->|"Feedback αισθητήρων"| M1_D
    M1_W   -.->|"Εκπλυσμός"| M1_EV
    M1_MOT -->|"30–60 min → Εκκένωση"| M1_EV

    %% ── Malaxator 2 ────────────────────────────────────────────────
    M2_FV  --> M2_MOT
    M2_H   -.->|"Θέρμανση σερπαντίνας"| M2_MOT
    M2_MOT -->|"Παρακολούθηση"| M2_S
    M2_S   -->|"Feedback αισθητήρων"| M2_D
    M2_W   -.->|"Εκπλυσμός"| M2_EV
    M2_MOT -->|"30–60 min → Εκκένωση"| M2_EV

    %% ── Malaxator N ────────────────────────────────────────────────
    MN_FV  --> MN_MOT
    MN_H   -.->|"Θέρμανση σερπαντίνας"| MN_MOT
    MN_MOT -->|"Παρακολούθηση"| MN_S
    MN_S   -->|"Feedback αισθητήρων"| MN_D
    MN_W   -.->|"Εκπλυσμός"| MN_EV
    MN_MOT -->|"30–60 min → Εκκένωση"| MN_EV

    %% ── Drain Valves → Extraction ──────────────────────────────────
    M1_EV -->|"Εκκένωση Μαλακτήρα ①"| FPUMP
    M2_EV -->|"Εκκένωση Μαλακτήρα ②"| FPUMP
    MN_EV -->|"Εκκένωση Μαλακτήρα Ν"| FPUMP

    %% ── Extraction & Decanting ─────────────────────────────────────
    FPUMP --> ISCR
    ISCR  --> FMAL
    FMAL  --> APUMP
    APUMP --> DEC
    DEC   --> OIL
    DEC   --> POMACE

